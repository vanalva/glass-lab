  "brand": "glass-lab",
  "grid": {
    "cols": 18,
    "mainRows": 7,
    "offsetRows": 2,
    "totalSlots": 118,
    "comment": "Real periodic-table topology — H position is the brand monogram (outside numbered slots). Numbered slots 1-118 follow region-fill order: COLORES (1-15 + 16-17 empty) → INSERCIONES top-right block (18-30) → INSERCIONES mesh row (31-45) → INSERCIONES rest (46-90) → REFLECTIVOS lanthanide row (91-104) → REFLECTIVOS actinide row (105-118 empty)."
  },
  "monogram": {
    "type": "monogram",
    "row": 1,
    "col": 1,
    "atomicNumber": 14,
    "atomicMass": "28.086",
    "symbol": "GL",
    "subtitle": "SiO₂",
    "rationale": "Silicon (atomic #14, mass 28.086) is the chemistry of glass. The GL monogram occupies the H position of the periodic table — the brand IS the substrate."
  },
